# ============================================================
# AI Portfolio Analyzer — .gitignore
# ============================================================

# ── Secrets ──────────────────────────────────────────────────
.env
*.key
secrets/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.installed.cfg

# ── Virtual environments ─────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Data (raw & processed) ───────────────────────────────────
data/raw/
data/processed/
# Uncomment below to ALSO ignore notebooks outputs:
# notebooks/.ipynb_checkpoints/

# ── Model checkpoints ────────────────────────────────────────
checkpoints/
# Keep the directory itself
!checkpoints/.gitkeep

# ── Reports & figures ────────────────────────────────────────
reports/figures/*.html
reports/figures/*.png
reports/figures/*.pdf

# ── Weights & Biases ─────────────────────────────────────────
wandb/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Coverage / testing ───────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
